{
  "kind": "review-project-flow",
  "version": 1,
  "description": "Project-level code review. Runs a single LLM review step using the review-project prompt template. Used internally by the review command when no prior design/plan artifacts are present.",
  "catalogVisibility": "hidden",
  "phases": [
    {
      "id": "review",
      "steps": [
        {
          "id": "run_review",
          "node": "llm-prompt",
          "routingGroup": "review",
          "prompt": {
            "templateRef": "review-project",
            "vars": {
              "review_file": {
                "artifact": {
                  "kind": "review-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "review_json_file": {
                "artifact": {
                  "kind": "review-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "ready_to_merge_file": {
                "artifact": {
                  "kind": "ready-to-merge-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": {
              "template": "Running project review mode (iteration {iteration})",
              "vars": {
                "iteration": { "ref": "params.iteration" }
              }
            },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "review-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "review-json-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "review-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  }
                ]
              },
              "message": "Project review did not produce the required review artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "review-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  },
                  "schemaId": "review-findings/v1"
                }
              ],
              "message": "Project review produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "review_verdict",
          "node": "review-verdict",
          "when": { "not": { "ref": "context.dryRun" } },
          "params": {
            "taskKey": { "ref": "params.taskKey" },
            "iteration": { "ref": "params.iteration" },
            "blockingSeverities": { "ref": "params.reviewBlockingSeverities" }
          }
        }
      ]
    }
  ]
}
