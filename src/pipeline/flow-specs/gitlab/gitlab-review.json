{
  "kind": "gitlab-review-flow",
  "version": 1,
  "description": "Prompts for a GitLab merge request URL, fetches existing code review comments via GitLab API, assesses which findings are fair and which can be dismissed, then runs review-fix to apply fixes for the accepted findings.",
  "phases": [
    {
      "id": "gitlab_review",
      "steps": [
        {
          "id": "collect_merge_request_url",
          "node": "user-input",
          "params": {
            "formId": { "const": "gitlab-review-input" },
            "title": { "const": "GitLab Review" },
            "description": { "const": "Provide a GitLab merge request URL to fetch code review comments." },
            "fields": {
              "const": [
                {
                  "id": "merge_request_url",
                  "type": "text",
                  "label": "GitLab MR URL",
                  "help": "Example: https://gitlab.example.com/group/project/-/merge_requests/123",
                  "required": true,
                  "placeholder": "https://gitlab.example.com/group/project/-/merge_requests/123"
                }
              ]
            },
            "outputFile": {
              "artifact": {
                "kind": "gitlab-review-input-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "gitlab-review-input-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "user-input/v1"
                }
              ],
              "message": "GitLab review input form produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "fetch_gitlab_review",
          "node": "fetch-gitlab-review",
          "params": {
            "mergeRequestUrl": { "ref": "steps.gitlab_review.collect_merge_request_url.value.values.merge_request_url" },
            "outputFile": {
              "artifact": {
                "kind": "gitlab-review-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "ref": "params.gitlabReviewIteration" }
              }
            },
            "outputJsonFile": {
              "artifact": {
                "kind": "gitlab-review-json-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "ref": "params.gitlabReviewIteration" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "path": {
                "artifact": {
                  "kind": "gitlab-review-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.gitlabReviewIteration" }
                }
              },
              "message": "Fetch GitLab review node did not produce the markdown artifact."
            },
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "gitlab-review-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.gitlabReviewIteration" }
                    }
                  },
                  "schemaId": "gitlab-review/v1"
                }
              ],
              "message": "Fetch GitLab review node produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "assess_gitlab_review",
          "when": { "not": { "ref": "context.dryRun" } },
          "node": "llm-prompt",
          "routingGroup": "review",
          "prompt": {
            "templateRef": "gitlab-review",
            "vars": {
              "gitlab_review_file": {
                "artifact": {
                  "kind": "gitlab-review-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.gitlabReviewIteration" }
                }
              },
              "gitlab_review_json_file": {
                "artifact": {
                  "kind": "gitlab-review-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.gitlabReviewIteration" }
                }
              },
              "review_file": {
                "artifact": {
                  "kind": "review-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "review_json_file": {
                "artifact": {
                  "kind": "review-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "review_assessment_file": {
                "artifact": {
                  "kind": "review-assessment-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "review_assessment_json_file": {
                "artifact": {
                  "kind": "review-assessment-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": {
              "template": "Assessing GitLab findings and proposed fixes (iteration {iteration})",
              "vars": {
                "iteration": { "ref": "params.iteration" }
              }
            },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "review-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "review-json-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "review-assessment-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "review-assessment-json-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "paths": {
                "list": [
                  {
                    "artifact": {
                      "kind": "review-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  },
                  {
                    "artifact": {
                      "kind": "review-assessment-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  }
                ]
              },
              "message": "GitLab review assessment did not produce the required artifacts."
            },
            {
              "kind": "require-structured-artifacts",
              "when": { "not": { "ref": "context.dryRun" } },
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "review-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  },
                  "schemaId": "review-findings/v1"
                },
                {
                  "path": {
                    "artifact": {
                      "kind": "review-assessment-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  },
                  "schemaId": "review-assessment/v1"
                }
              ],
              "message": "GitLab review assessment produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "run_review_fix",
          "when": { "not": { "ref": "context.dryRun" } },
          "node": "flow-run",
          "params": {
            "fileName": { "const": "review-fix.json" },
            "labelText": {
              "template": "Running review-fix for GitLab review (iteration {iteration})",
              "vars": {
                "iteration": { "ref": "params.iteration" }
              }
            },
            "taskKey": { "ref": "params.taskKey" },
            "latestIteration": { "ref": "params.iteration" },
            "reviewAssessmentJsonFile": {
              "artifact": {
                "kind": "review-assessment-json-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "ref": "params.iteration" }
              }
            },
            "reviewFixSelectionJsonFile": { "ref": "params.reviewFixSelectionJsonFile" },
            "reviewFixPoints": { "ref": "params.reviewFixPoints" },
            "reviewBlockingSeverities": { "ref": "params.reviewBlockingSeverities" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmModel": { "ref": "params.llmModel" },
            "llmExecutor": { "ref": "params.llmExecutor" }
          }
        }
      ]
    }
  ]
}
