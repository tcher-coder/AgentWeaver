{
  "kind": "task-describe-flow",
  "version": 1,
  "description": "Generates a brief task description from a Jira issue, uploaded task source file, or manual input. When Jira is provided, fetches the issue and summarizes it; otherwise analyzes the supplied source and repository context to produce a richer description.",
  "phases": [
    {
      "id": "task_describe",
      "steps": [
        {
          "id": "collect_task_source",
          "node": "user-input",
          "params": {
            "formId": { "const": "task-describe-source-input" },
            "title": { "const": "Task Describe Source" },
            "description": {
              "const": "Provide exactly one task source: Jira issue key / browse URL, uploaded text file, or manual description. Additional instructions can supplement any source."
            },
            "submitLabel": { "const": "Generate description" },
            "fields": {
              "list": [
                {
                  "const": {
                    "id": "jira_ref",
                    "type": "text",
                    "label": "Jira issue key or browse URL",
                    "help": "Example: DEMO-3288 or https://jira.example.com/browse/DEMO-3288. Leave empty when using a file upload or manual description.",
                    "required": false
                  }
                },
                {
                  "const": {
                    "id": "task_file",
                    "type": "text-file",
                    "label": "Task source file",
                    "help": "Upload one UTF-8 .md, .markdown, .txt, or .xml file up to 512 KiB. Leave empty when using Jira or manual description.",
                    "required": false,
                    "accept": [".md", ".markdown", ".txt", ".xml", "text/plain", "text/markdown", "text/xml", "application/xml"],
                    "maxBytes": 524288,
                    "buttonLabel": "Upload file"
                  }
                },
                {
                  "const": {
                    "id": "additional_instructions",
                    "type": "text",
                    "label": "Additional instructions",
                    "help": "Optional instructions for description generation. Example: link to another local repo, related project, constraints, or useful context.",
                    "required": false,
                    "multiline": true,
                    "rows": 4,
                    "placeholder": "e.g. see also ../billing-service, API docs in docs/task-templates.md"
                  }
                },
                {
                  "const": {
                    "id": "task_description",
                    "type": "text",
                    "label": "Task description",
                    "help": "Briefly describe the task in your own words. Fill this field only if Jira and file upload are not used.",
                    "required": false,
                    "multiline": true,
                    "rows": 3,
                    "placeholder": "e.g. add a status filter to the order list and persist the selected value in the URL"
                  }
                }
              ]
            },
            "outputFile": {
              "artifact": {
                "kind": "task-describe-input-json-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "task-describe-input-json-file",
                      "taskKey": { "ref": "params.taskKey" }
                    }
                  },
                  "schemaId": "user-input/v1"
                }
              ],
              "message": "Task describe source input is missing or invalid."
            }
          ]
        },
        {
          "id": "resolve_jira_context",
          "node": "jira-context",
          "when": {
            "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
          },
          "params": {
            "jiraRef": {
              "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
            }
          }
        },
        {
          "id": "fetch_jira",
          "node": "jira-fetch",
          "when": {
            "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
          },
          "params": {
            "jiraApiUrl": { "ref": "steps.task_describe.resolve_jira_context.value.jiraApiUrl" },
            "outputFile": {
              "artifact": {
                "kind": "jira-task-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "attachmentsManifestFile": {
              "artifact": {
                "kind": "jira-attachments-manifest-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            },
            "attachmentsContextFile": {
              "artifact": {
                "kind": "jira-attachments-context-file",
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "path": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Jira fetch node did not produce the Jira task file."
            },
            {
              "kind": "require-file",
              "path": {
                "artifact": {
                  "kind": "jira-attachments-manifest-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Jira fetch node did not produce the Jira attachments manifest file."
            },
            {
              "kind": "require-file",
              "path": {
                "artifact": {
                  "kind": "jira-attachments-context-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "message": "Jira fetch node did not produce the Jira attachments context file."
            }
          ]
        },
        {
          "id": "run_task_describe_from_jira",
          "node": "llm-prompt",
          "routingGroup": "planning",
          "when": {
            "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
          },
          "prompt": {
            "templateRef": "task-describe",
            "vars": {
              "jira_task_file": {
                "artifact": {
                  "kind": "jira-task-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_attachments_manifest_file": {
                "artifact": {
                  "kind": "jira-attachments-manifest-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_attachments_context_file": {
                "artifact": {
                  "kind": "jira-attachments-context-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_description_file": {
                "artifact": {
                  "kind": "jira-description-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "jira_description_json_file": {
                "artifact": {
                  "kind": "jira-description-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              }
            },
            "extraPrompt": {
              "appendPrompt": {
                "base": { "ref": "params.extraPrompt" },
                "suffix": { "ref": "steps.task_describe.collect_task_source.value.promptSuffix" }
              }
            },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running task description mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "jira-description-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "jira-description-json-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "when": { "not": { "ref": "context.dryRun" } },
              "path": {
                "artifact": {
                  "kind": "jira-description-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "message": "Task describe mode did not produce the Jira description artifact."
            }
          ]
        },
        {
          "id": "ensure_task_describe_json_from_jira_markdown",
          "node": "ensure-summary-json",
          "when": {
            "all": [
              { "ref": "steps.task_describe.collect_task_source.value.values.jira_ref" },
              { "not": { "ref": "context.dryRun" } }
            ]
          },
          "params": {
            "markdownFile": {
              "artifact": {
                "kind": "jira-description-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "ref": "params.iteration" }
              }
            },
            "outputFile": {
              "artifact": {
                "kind": "jira-description-json-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "ref": "params.iteration" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "jira-description-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  },
                  "schemaId": "jira-description/v1"
                }
              ],
              "message": "Task describe mode produced invalid structured artifacts."
            }
          ]
        },
        {
          "id": "run_task_describe_from_input",
          "node": "llm-prompt",
          "routingGroup": "planning",
          "when": {
            "not": {
              "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
            }
          },
          "prompt": {
            "inlineTemplate": "Review the user-provided task source metadata in {task_input_file}. If values.task_file is present, use the raw uploaded task source artifact at {task_source_file} as the primary source of truth and use values.task_file only as metadata. If values.task_file is not present, use values.task_description as the source of truth. Treat XML uploads as plain text; do not parse XML, expand entities, or validate XML schemas. Study the repository code relevant to the task before writing the description, and use that analysis to add concise context about the current behavior, existing routes/modules, contracts, DTOs, or missing pieces directly related to the request. The result must be richer than a paraphrase of the input, but do not invent requirements that are not supported by the user source or the code. Formulate a typical Jira task description in simple product language, without overloading with technical details. Description structure: Problem, Context, What needs to be done, Acceptance criteria. Add concrete implementation context when it is supported by the code: mention where changes are likely needed, including specific routes, handlers, services, DTOs, API contracts, validation rules, repository methods, events, or UI screens. If the user source lacks details, do not invent them and keep formulations general enough. The source-of-truth JSON must be in English for all generated semantic string values, while verbatim user-provided source text may be preserved as needed. First write the source-of-truth JSON to {jira_description_json_file} as object { summary: string }, then the markdown version to {jira_description_file}.",
            "vars": {
              "task_input_file": {
                "artifact": {
                  "kind": "task-describe-input-json-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "task_source_file": {
                "artifact": {
                  "kind": "task-source-file",
                  "taskKey": { "ref": "params.taskKey" }
                }
              },
              "jira_description_file": {
                "artifact": {
                  "kind": "jira-description-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "jira_description_json_file": {
                "artifact": {
                  "kind": "jira-description-json-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              }
            },
            "extraPrompt": {
              "appendPrompt": {
                "base": { "ref": "params.extraPrompt" },
                "suffix": { "ref": "steps.task_describe.collect_task_source.value.promptSuffix" }
              }
            },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running task description mode" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" },
            "requiredArtifacts": {
              "list": [
                {
                  "artifact": {
                    "kind": "jira-description-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                },
                {
                  "artifact": {
                    "kind": "jira-description-json-file",
                    "taskKey": { "ref": "params.taskKey" },
                    "iteration": { "ref": "params.iteration" }
                  }
                }
              ]
            }
          },
          "expect": [
            {
              "kind": "require-file",
              "when": { "not": { "ref": "context.dryRun" } },
              "path": {
                "artifact": {
                  "kind": "jira-description-file",
                  "taskKey": { "ref": "params.taskKey" },
                  "iteration": { "ref": "params.iteration" }
                }
              },
              "message": "Task describe mode did not produce the Jira description artifact."
            }
          ]
        },
        {
          "id": "ensure_task_describe_json_from_input_markdown",
          "node": "ensure-summary-json",
          "when": {
            "all": [
              {
                "not": {
                  "ref": "steps.task_describe.collect_task_source.value.values.jira_ref"
                }
              },
              { "not": { "ref": "context.dryRun" } }
            ]
          },
          "params": {
            "markdownFile": {
              "artifact": {
                "kind": "jira-description-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "ref": "params.iteration" }
              }
            },
            "outputFile": {
              "artifact": {
                "kind": "jira-description-json-file",
                "taskKey": { "ref": "params.taskKey" },
                "iteration": { "ref": "params.iteration" }
              }
            }
          },
          "expect": [
            {
              "kind": "require-structured-artifacts",
              "items": [
                {
                  "path": {
                    "artifact": {
                      "kind": "jira-description-json-file",
                      "taskKey": { "ref": "params.taskKey" },
                      "iteration": { "ref": "params.iteration" }
                    }
                  },
                  "schemaId": "jira-description/v1"
                }
              ],
              "message": "Task describe mode produced invalid structured artifacts."
            }
          ]
        }
      ]
    }
  ]
}
