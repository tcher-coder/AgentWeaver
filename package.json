{
  "name": "agentweaver",
  "version": "0.1.20",
  "description": "CLI orchestrator for Jira/Codex engineering workflows",
  "keywords": [
    "agent",
    "cli",
    "jira",
    "codex",
    "tui",
    "developer-tools"
  ],
  "homepage": "https://github.com/seko99/AgentWeaver#readme",
  "bugs": {
    "url": "https://github.com/seko99/AgentWeaver/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seko99/AgentWeaver.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./plugin-sdk": "./dist/plugin-sdk.js"
  },
  "bin": {
    "agentweaver": "dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "run_go_tests.py",
    "run_go_linter.py",
    "run_go_coverage.sh"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "npm@9.2.0",
  "preferGlobal": true,
  "scripts": {
    "build": "npm run build:web-css && tsc -p tsconfig.json && node scripts/copy-flow-specs.mjs",
    "build:web-css": "tailwindcss -i ./src/interactive/web/static/styles.input.css -o ./src/interactive/web/static/styles.css --minify",
    "dev:web-css": "tailwindcss -i ./src/interactive/web/static/styles.input.css -o ./src/interactive/web/static/styles.css --watch",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run check && npm run build",
    "pack:check": "npm pack --dry-run",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts"
  },
  "engines": {
    "node": ">=18.19.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.12",
    "@types/semver": "^7.7.1",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "markdown-it": "^14.1.1",
    "react": "^18.3.1",
    "semver": "^7.7.4",
    "yaml": "^2.8.1"
  }
}
