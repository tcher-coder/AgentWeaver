{
  "kind": "auto-flow",
  "version": 1,
  "description": "End-to-end resumable pipeline for Go projects. Runs the full sequence: task source collection → task source normalization → plan → design-review loop → implement → linter loop → test loop → review loop → final linter loop → final test loop. Supports --from to restart from a specific phase and auto-status/auto-reset for state management.",
  "constants": {
    "autoReviewFixExtraPrompt": "Fix only blockers, criticals, and important findings"
  },
  "phases": [
    {
      "id": "source",
      "steps": [
        {
          "id": "fetch_jira_source",
          "when": { "ref": "params.jiraApiUrl" },
          "node": "flow-run",
          "params": {
            "fileName": { "const": "jira-fetch.json" },
            "labelText": { "const": "Fetching Jira task source" },
            "jiraApiUrl": { "ref": "params.jiraApiUrl" },
            "taskKey": { "ref": "params.taskKey" }
          }
        },
        {
          "id": "collect_manual_source",
          "when": { "not": { "ref": "params.jiraApiUrl" } },
          "node": "flow-run",
          "params": {
            "fileName": { "const": "manual-jira-input.json" },
            "labelText": { "const": "Collecting manual Jira task source" },
            "taskKey": { "ref": "params.taskKey" },
            "manualTaskDescription": { "ref": "params.manualTaskDescription" }
          }
        }
      ]
    },
    {
      "id": "normalize",
      "steps": [
        {
          "id": "run_normalize_source",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "normalize-task-source.json" },
            "labelText": { "const": "Normalizing task source" },
            "taskKey": { "ref": "params.taskKey" },
            "iteration": { "ref": "params.taskContextIteration" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" },
            "extraPrompt": { "ref": "params.extraPrompt" }
          }
        }
      ]
    },
    {
      "id": "plan",
      "steps": [
        {
          "id": "run_plan_flow",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "plan.json" },
            "labelText": { "const": "Running planning flow" },
            "taskKey": { "ref": "params.taskKey" },
            "taskContextIteration": { "ref": "params.taskContextIteration" },
            "designIteration": { "ref": "params.designIteration" },
            "planIteration": { "ref": "params.planIteration" },
            "qaIteration": { "ref": "params.qaIteration" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "mdLang": { "ref": "params.mdLang" }
          }
        }
      ]
    },
    {
      "id": "design_review_loop",
      "steps": [
        {
          "id": "run_design_review_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "design-review-loop.json" },
            "labelText": { "const": "Running design-review loop" },
            "taskKey": { "ref": "params.taskKey" },
            "baseIteration": { "ref": "params.designReviewBaseIteration" },
            "workspaceDir": { "ref": "params.workspaceDir" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" }
          },
          "stopFlowIf": {
            "equals": [
              { "ref": "steps.design_review_loop.run_design_review_loop.value.executionState.terminationOutcome" },
              { "const": "stopped" }
            ]
          },
          "stopFlowOutcome": "stopped"
        }
      ]
    },
    {
      "id": "implement",
      "steps": [
        {
          "id": "resolve_planning_bundle",
          "node": "planning-bundle",
          "params": {
            "taskKey": { "ref": "params.taskKey" }
          }
        },
        {
          "id": "run_implement",
          "node": "llm-prompt",
          "routingGroup": "implementation",
          "prompt": {
            "templateRef": "implement",
            "vars": {
              "design_file": { "ref": "steps.implement.resolve_planning_bundle.value.designFile" },
              "design_json_file": { "ref": "steps.implement.resolve_planning_bundle.value.designJsonFile" },
              "plan_file": { "ref": "steps.implement.resolve_planning_bundle.value.planFile" },
              "plan_json_file": { "ref": "steps.implement.resolve_planning_bundle.value.planJsonFile" },
              "qa_file": { "ref": "steps.implement.resolve_planning_bundle.value.qaFile" },
              "qa_json_file": { "ref": "steps.implement.resolve_planning_bundle.value.qaJsonFile" }
            },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "format": "task-prompt"
          },
          "params": {
            "labelText": { "const": "Running implementation mode locally" },
            "model": { "ref": "params.llmModel" },
            "executor": { "ref": "params.llmExecutor" }
          }
        },
        {
          "id": "notify_implement_complete",
          "node": "telegram-notify",
          "params": {
            "message": {
              "template": "Implementation phase for {taskKey} complete.",
              "vars": {
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          }
        }
      ]
    },
    {
      "id": "after_implement_checks",
      "steps": [
        {
          "id": "run_go_linter_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "run-go-linter-loop.json" },
            "labelText": { "const": "Running final linter check" },
            "taskKey": { "ref": "params.taskKey" },
            "runGoLinterScript": { "ref": "params.runGoLinterScript" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" },
            "runGoLinterIteration": { "ref": "params.runGoLinterIteration" }
          }
        },
        {
          "id": "notify_linter_loop_complete",
          "node": "telegram-notify",
          "params": {
            "message": {
              "template": "Linter loop for {taskKey} complete.",
              "vars": {
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          }
        },
        {
          "id": "run_go_tests_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "run-go-tests-loop.json" },
            "labelText": { "const": "Running final tests check" },
            "taskKey": { "ref": "params.taskKey" },
            "runGoTestsScript": { "ref": "params.runGoTestsScript" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" },
            "runGoTestsIteration": { "ref": "params.runGoTestsIteration" }
          }
        },
        {
          "id": "notify_tests_loop_complete",
          "node": "telegram-notify",
          "params": {
            "message": {
              "template": "Tests loop for {taskKey} complete.",
              "vars": {
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          }
        }
      ]
    },
    {
      "id": "review_loop",
      "steps": [
        {
          "id": "run_review_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "review-loop.json" },
            "labelText": { "const": "Running review-loop" },
            "taskKey": { "ref": "params.taskKey" },
            "baseIteration": { "ref": "params.baseIteration" },
            "workspaceDir": { "ref": "params.workspaceDir" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "reviewFixPoints": { "ref": "params.reviewFixPoints" },
            "reviewBlockingSeverities": { "ref": "params.reviewBlockingSeverities" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" }
          }
        },
        {
          "id": "notify_review_loop_complete",
          "node": "telegram-notify",
          "params": {
            "message": {
              "template": "Review loop for {taskKey} complete.",
              "vars": {
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          }
        }
      ]
    },
    {
      "id": "final_checks",
      "steps": [
        {
          "id": "run_go_linter_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "run-go-linter-loop.json" },
            "labelText": { "const": "Running final linter check" },
            "taskKey": { "ref": "params.taskKey" },
            "runGoLinterScript": { "ref": "params.runGoLinterScript" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" },
            "runGoLinterIteration": { "ref": "params.runGoLinterIteration" }
          }
        },
        {
          "id": "notify_final_linter_loop_complete",
          "node": "telegram-notify",
          "params": {
            "message": {
              "template": "Final linter loop for {taskKey} complete.",
              "vars": {
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          }
        },
        {
          "id": "run_go_tests_loop",
          "node": "flow-run",
          "params": {
            "fileName": { "const": "run-go-tests-loop.json" },
            "labelText": { "const": "Running final tests check" },
            "taskKey": { "ref": "params.taskKey" },
            "runGoTestsScript": { "ref": "params.runGoTestsScript" },
            "extraPrompt": { "ref": "params.extraPrompt" },
            "llmExecutor": { "ref": "params.llmExecutor" },
            "llmModel": { "ref": "params.llmModel" },
            "runGoTestsIteration": { "ref": "params.runGoTestsIteration" }
          }
        },
        {
          "id": "notify_final_tests_loop_complete",
          "node": "telegram-notify",
          "params": {
            "message": {
              "template": "Final tests loop for {taskKey} complete.",
              "vars": {
                "taskKey": { "ref": "params.taskKey" }
              }
            }
          }
        }
      ]
    }
  ]
}
